{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "strictNullChecks": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",  // ✅ REQUIRED
    "paths": {
      "@/app/components/*": ["my-sanity-site/frontend/app/components/*"],
      "@/sanity/*": ["my-sanity-site/frontend/sanity/*"],
      "@/sanity/lib/*": ["my-sanity-site/frontend/sanity/lib/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
